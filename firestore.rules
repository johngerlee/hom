rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.uid in [
        "ZtvlRwemOCYMrimzKkZFGqvoBxF3",
        "FfCr7aUTonfCMPU9nUXoCYUlk5m1"
    ];

    match /growthApp/{document=**} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
